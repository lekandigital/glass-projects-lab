{
  "name": "@liquid-dom/layout",
  "version": "0.2.0",
  "description": "A renderer-agnostic JavaScript layout engine inspired by SwiftUI layout.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./animation": {
      "types": "./dist/animation.d.ts",
      "import": "./dist/animation.js",
      "require": "./dist/animation.cjs"
    },
    "./dom": {
      "types": "./dist/dom.d.ts",
      "import": "./dist/dom.js",
      "require": "./dist/dom.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 playground",
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "playground:build": "vite build playground",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build && npm run playground:build"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^27.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.0.15"
  }
}
