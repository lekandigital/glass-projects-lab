{
  "name": "@liquid-dom/core",
  "version": "0.1.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./layout": {
      "types": "./dist/layout.d.ts",
      "import": "./dist/layout.js",
      "require": "./dist/layout.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "watch": "tsup --watch"
  },
  "dependencies": {
    "@liquid-dom/layout": "workspace:*"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.69",
    "jsdom": "^27.2.0",
    "tsup": "^8.5.0",
    "typescript": "~6.0.2",
    "vitest": "^4.0.15"
  }
}
