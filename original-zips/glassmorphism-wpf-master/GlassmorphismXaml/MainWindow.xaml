<Window x:Class="GlassmorphismWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Glassmorphism WPF Demo"
        Height="600"
        Width="900"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <!-- Glassmorphism Card Style -->
        <Style x:Key="GlassmorphismCard" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.2">
                        <GradientStop Color="#FFFFFF" Offset="0" />
                        <GradientStop Color="#FFFFFF" Offset="0.3" />
                        <GradientStop Color="#E0E0E0" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#40FFFFFF" Offset="0" />
                        <GradientStop Color="#20FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="15" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20"
                                      ShadowDepth="5"
                                      Direction="315"
                                      Color="#40000000"
                                      Opacity="0.3" />
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Button Style -->
        <Style x:Key="GlassButton" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.3">
                        <GradientStop Color="#60FFFFFF" Offset="0" />
                        <GradientStop Color="#40FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#60FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.5">
                                            <GradientStop Color="#80FFFFFF" Offset="0" />
                                            <GradientStop Color="#60FFFFFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.7">
                                            <GradientStop Color="#A0FFFFFF" Offset="0" />
                                            <GradientStop Color="#80FFFFFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>        <!-- Glass TextBox Style -->
        <Style x:Key="GlassTextBox" TargetType="TextBox">
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="#20FFFFFF" />
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#40FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="SelectionBrush" Value="#60FFFFFF" />
            <Setter Property="Height" Value="35" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Name="border">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.56" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#60FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#80FFFFFF" />
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#30FFFFFF" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Background with gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#667eea" Offset="0" />
                <GradientStop Color="#764ba2" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Background patterns/shapes for visual interest -->
        <Canvas>
            <Ellipse Width="200" Height="200"
                     Canvas.Left="100" Canvas.Top="50">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#40FF6B6B" Offset="0" />
                        <GradientStop Color="#00FF6B6B" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Ellipse Width="150" Height="150"
                     Canvas.Right="80" Canvas.Bottom="100">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#404ECDC4" Offset="0" />
                        <GradientStop Color="#004ECDC4" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Rectangle Width="100" Height="100"
                       Canvas.Right="200" Canvas.Top="150">
                <Rectangle.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#40FFE66D" Offset="0" />
                        <GradientStop Color="#00FFE66D" Offset="1" />
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Canvas>

        <!-- Main Content -->
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">

            <!-- Glassmorphism Card -->
            <Border Style="{StaticResource GlassmorphismCard}"
                    Width="400"
                    Height="500"
                    ClipToBounds="True">
                <!-- Backdrop blur effect simulation -->
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.15">
                        <GradientStop Color="#FFFFFF" Offset="0" />
                        <GradientStop Color="#FFFFFF" Offset="0.3" />
                        <GradientStop Color="#E0E0E0" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="25">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Welcome Back"
                                   FontSize="28"
                                   FontWeight="Light"
                                   Foreground="White"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Sign in to your account"
                                   FontSize="14"
                                   Foreground="#E0FFFFFF"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,0" />
                    </StackPanel>

                    <!-- Profile Avatar -->
                    <Border Grid.Row="1"
                            Width="80"
                            Height="80"
                            CornerRadius="40"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,25">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF6B6B" Offset="0" />
                                <GradientStop Color="#4ECDC4" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="JD"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <!-- Form Content -->
                    <StackPanel Grid.Row="2">
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Email"
                                       Foreground="#E0FFFFFF"
                                       FontSize="12"
                                       Margin="0,0,0,5" />
                            <TextBox Style="{StaticResource GlassTextBox}"
                                     Text=""
                                     Name="EmailTextBox" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Password"
                                       Foreground="#E0FFFFFF"
                                       FontSize="12"
                                       Margin="0,0,0,5" />
                            <PasswordBox Height="35"
                                         Background="#20FFFFFF"
                                         BorderBrush="#40FFFFFF"
                                         BorderThickness="1"
                                         Foreground="White"
                                         Padding="10,8">
                                <PasswordBox.Template>
                                    <ControlTemplate TargetType="PasswordBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Margin="{TemplateBinding Padding}"
                                                          VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </PasswordBox.Template>
                            </PasswordBox>
                        </StackPanel>
                    </StackPanel>

                    <!-- Actions -->
                    <StackPanel Grid.Row="3" Margin="0,15,0,0">
                        <Button Content="Sign In"
                                Style="{StaticResource GlassButton}"
                                Margin="0,0,0,10" />

                        <TextBlock HorizontalAlignment="Center">
                            <Run Text="Don't have an account? " Foreground="#C0FFFFFF" FontSize="12" />
                            <Run Text="Sign up" Foreground="White" FontSize="12" TextDecorations="Underline" />
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Close button -->
        <Button Content="✕"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Width="30"
                Height="30"
                Margin="10"
                Background="Transparent"
                BorderThickness="0"
                Foreground="White"
                FontSize="16"
                Click="CloseButton_Click" />
    </Grid>
</Window>
